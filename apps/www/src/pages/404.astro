---
import NotFoundPage from "../components/NotFoundPage.astro";
import { getLocale, locales, type Locale } from "../i18n";

export const prerender = false;

const pathLocale = Astro.url.pathname.split("/").find((segment) =>
	locales.includes(segment as Locale),
);
const locale = getLocale(Astro.currentLocale ?? pathLocale);
---

<NotFoundPage locale={locale} />
