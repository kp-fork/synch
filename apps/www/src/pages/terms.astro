---
import { getEntry, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const entry = await getEntry('legal', 'terms-of-service');
const rendered = entry ? await render(entry) : undefined;
const Content = rendered?.Content;
---

<Layout
	title={entry ? `${entry.data.title} - Synch` : "Terms of Service - Synch"}
	description={entry?.data.description ?? "Terms that apply to the hosted Synch service."}
>
	<div class="max-w-2xl mx-auto px-6 w-full flex-1 flex flex-col">
		<Header />

		<main class="flex-1 flex flex-col py-24">
			{
				entry && Content ? (
					<article class="legal-content">
						<h1 class="text-2xl sm:text-3xl text-zinc-200 tracking-tight mb-4">{entry.data.title}</h1>
						{entry.data.description && <p class="text-zinc-500 mb-12 text-base">{entry.data.description}</p>}
						<div class="h-px bg-zinc-800/50 w-full mb-12"></div>
						<Content />
					</article>
				) : (
					<section>
						<h1 class="text-2xl sm:text-3xl text-zinc-200 tracking-tight mb-8">Terms of Service</h1>
						<p class="text-zinc-500">Terms content has not been added yet.</p>
					</section>
				)
			}
		</main>

		<Footer />
	</div>
</Layout>

<style is:global>
	@reference "../styles/global.css";
	.legal-content h2 {
		@apply text-lg font-medium text-zinc-200 mt-12 mb-4;
	}
	.legal-content h3 {
		@apply text-base font-medium text-zinc-300 mt-8 mb-4;
	}
	.legal-content p {
		@apply text-zinc-400 mb-6 leading-relaxed;
	}
	.legal-content ul {
		@apply list-disc list-outside ml-4 text-zinc-400 mb-6 space-y-2;
	}
	.legal-content li::marker {
		@apply text-zinc-700;
	}
	.legal-content a {
		@apply text-zinc-300 border-b border-zinc-700 hover:text-zinc-100 hover:border-zinc-500 transition-colors;
	}
	.legal-content strong {
		@apply font-medium text-zinc-300;
	}
</style>
