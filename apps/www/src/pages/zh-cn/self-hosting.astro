---
import { getEntry, render } from "astro:content";
import SelfHostingPage from "../../components/SelfHostingPage.astro";

const doc = await getEntry("docs", "self-hosting/zh-cn");
if (!doc) {
  throw new Error("Missing Simplified Chinese self-hosting docs entry.");
}

const { Content } = await render(doc);
---

<SelfHostingPage Content={Content} doc={doc} locale="zh-cn" />
