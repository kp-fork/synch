---
import '../styles/global.css';
import {
	defaultLocale,
	getLocale,
	localeLanguageTags,
	locales,
	localizedPath,
	openGraphLocales,
	ui,
	unlocalizedPath,
	type Locale,
} from '../i18n';

interface Props {
	title?: string;
	description?: string;
	locale?: Locale;
	noindex?: boolean;
	alternatePath?: string | false;
	ogType?: "website" | "article";
	publishedTime?: Date;
	modifiedTime?: Date;
	jsonLd?: unknown;
}

const locale = Astro.props.locale ?? getLocale(Astro.currentLocale);
const {
	title = ui[locale].meta.defaultTitle,
	description = ui[locale].meta.defaultDescription,
	noindex = false,
	alternatePath = noindex ? false : unlocalizedPath(Astro.url.pathname),
	ogType = "website",
	publishedTime,
	modifiedTime,
	jsonLd,
} = Astro.props;
const siteUrl = Astro.site ?? Astro.url.origin;
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);
if (canonicalUrl.pathname !== "/" && !canonicalUrl.pathname.endsWith("/")) {
	canonicalUrl.pathname = `${canonicalUrl.pathname}/`;
}
const ogImageUrl = new URL("/og.png", Astro.site ?? Astro.url.origin);
const alternateLinks =
	alternatePath === false
		? []
		: locales.map((alternateLocale) => ({
				locale: alternateLocale,
				href: new URL(localizedPath(alternateLocale, alternatePath), siteUrl),
			}));
const xDefaultUrl =
	alternatePath === false ? undefined : new URL(localizedPath(defaultLocale, alternatePath), siteUrl);
---
<!doctype html>
<html lang={localeLanguageTags[locale]} class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		{noindex && <meta name="robots" content="noindex, nofollow" />}
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		{alternateLinks.map((link) => (
			<link rel="alternate" hreflang={localeLanguageTags[link.locale]} href={link.href} />
		))}
		{xDefaultUrl && <link rel="alternate" hreflang="x-default" href={xDefaultUrl} />}
		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:locale" content={openGraphLocales[locale]} />
		{alternateLinks
			.filter((link) => link.locale !== locale)
			.map((link) => (
				<meta property="og:locale:alternate" content={openGraphLocales[link.locale]} />
			))}
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:type" content="image/png" />
		{publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
		{modifiedTime && <meta property="article:modified_time" content={modifiedTime.toISOString()} />}
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
		{jsonLd && <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />}
		<title>{title}</title>
	</head>
	<body class="bg-[#0a0a0a] text-zinc-400 font-sans antialiased selection:bg-zinc-800 selection:text-zinc-200 min-h-screen flex flex-col text-sm">
		<slot />
	</body>
</html>
