---
import { type Locale } from "../i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const text = {
  en: {
    generatorTitle: "Create secret values",
    generatorBody:
      "Click the button, then paste each value into the matching Cloudflare field.",
    betterAuthLabel: "BETTER_AUTH_SECRET",
    syncTokenLabel: "SYNC_TOKEN_SECRET",
    generate: "Generate new secrets",
    copy: "Copy",
    copied: "Copied",
  },
  ko: {
    generatorTitle: "Secret 값 만들기",
    generatorBody:
      "버튼을 누른 뒤 각 값을 Cloudflare의 같은 이름 입력란에 붙여 넣으세요.",
    betterAuthLabel: "BETTER_AUTH_SECRET",
    syncTokenLabel: "SYNC_TOKEN_SECRET",
    generate: "새 secret 생성",
    copy: "복사",
    copied: "복사됨",
  },
  ja: {
    generatorTitle: "Secret 値を作成",
    generatorBody:
      "ボタンを押して、それぞれの値を Cloudflare の同じ名前の入力欄に貼り付けてください。",
    betterAuthLabel: "BETTER_AUTH_SECRET",
    syncTokenLabel: "SYNC_TOKEN_SECRET",
    generate: "新しい secret を作成",
    copy: "コピー",
    copied: "コピー済み",
  },
  "zh-cn": {
    generatorTitle: "创建 Secret 值",
    generatorBody:
      "点击按钮，然后把每个值粘贴到 Cloudflare 中同名的输入框。",
    betterAuthLabel: "BETTER_AUTH_SECRET",
    syncTokenLabel: "SYNC_TOKEN_SECRET",
    generate: "生成新的 secret",
    copy: "复制",
    copied: "已复制",
  },
  "zh-tw": {
    generatorTitle: "建立 Secret 值",
    generatorBody:
      "點擊按鈕，然後把每個值貼到 Cloudflare 中同名的輸入欄。",
    betterAuthLabel: "BETTER_AUTH_SECRET",
    syncTokenLabel: "SYNC_TOKEN_SECRET",
    generate: "產生新的 secret",
    copy: "複製",
    copied: "已複製",
  },
}[locale];
---

<section class="synch-secret-generator" data-secret-generator>
  <div>
    <div class="synch-secret-title">{text.generatorTitle}</div>
    <p>{text.generatorBody}</p>
  </div>

  <div class="synch-secret-fields">
    <div class="synch-secret-row">
      <label for={`better-auth-secret-${locale}`}>{text.betterAuthLabel}</label>
      <div class="synch-secret-control">
        <input id={`better-auth-secret-${locale}`} type="text" readonly data-secret-output="better-auth" />
        <button type="button" data-copy-secret="better-auth">{text.copy}</button>
      </div>
    </div>

    <div class="synch-secret-row">
      <label for={`sync-token-secret-${locale}`}>{text.syncTokenLabel}</label>
      <div class="synch-secret-control">
        <input id={`sync-token-secret-${locale}`} type="text" readonly data-secret-output="sync-token" />
        <button type="button" data-copy-secret="sync-token">{text.copy}</button>
      </div>
    </div>
  </div>

  <button type="button" class="synch-secret-generate-button" data-generate-secrets>
    {text.generate}
  </button>
</section>

<script define:vars={{ copyLabel: text.copy, copiedLabel: text.copied }}>
  const generators = document.querySelectorAll("[data-secret-generator]");

  function generateHexSecret() {
    const bytes = new Uint8Array(32);
    crypto.getRandomValues(bytes);
    return Array.from(bytes, (byte) => byte.toString(16).padStart(2, "0")).join("");
  }

  function generateSecrets(root) {
    const betterAuth = root.querySelector('[data-secret-output="better-auth"]');
    const syncToken = root.querySelector('[data-secret-output="sync-token"]');
    if (betterAuth instanceof HTMLInputElement) {
      betterAuth.value = generateHexSecret();
    }
    if (syncToken instanceof HTMLInputElement) {
      syncToken.value = generateHexSecret();
    }
  }

  async function copySecret(root, secretName) {
    const output = root.querySelector(`[data-secret-output="${secretName}"]`);
    const button = root.querySelector(`[data-copy-secret="${secretName}"]`);
    if (!(output instanceof HTMLInputElement) || !(button instanceof HTMLButtonElement)) {
      return;
    }

    await navigator.clipboard.writeText(output.value);
    button.textContent = copiedLabel;
    setTimeout(() => {
      button.textContent = copyLabel;
    }, 1500);
  }

  generators.forEach((root) => {
    root.querySelector("[data-generate-secrets]")?.addEventListener("click", () => {
      generateSecrets(root);
    });
    root.querySelectorAll("[data-copy-secret]").forEach((button) => {
      button.addEventListener("click", () => {
        copySecret(root, button.getAttribute("data-copy-secret"));
      });
    });

    generateSecrets(root);
  });
</script>
