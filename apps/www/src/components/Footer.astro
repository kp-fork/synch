---
import { getLocale, localizedPath, ui, type Locale, locales } from "../i18n";

interface Props {
  locale?: Locale;
}

const localeLabels: Record<Locale, string> = {
  en: "English",
  ko: "한국어",
  ja: "日本語",
  "zh-cn": "简体中文",
  "zh-tw": "繁體中文",
};

const locale = Astro.props.locale ?? getLocale(Astro.currentLocale);
const t = ui[locale].nav;
const routePath = Astro.url.pathname
  .replace(new RegExp(`^/${locale}(/|$)`), "")
  .replace(/^\//, "");
---

<footer class="py-8 text-xs text-zinc-600 flex flex-col sm:flex-row items-center justify-between gap-4">
  <p>
    Synch &copy; {new Date().getFullYear()}
    <span aria-hidden="true">&middot;</span>
    <a href="mailto:contact@synch.run" class="hover:text-zinc-400 transition-colors">contact@synch.run</a>
  </p>
  <nav class="flex items-center gap-4">
    <select
      class="bg-transparent text-zinc-600 hover:text-zinc-400 transition-colors cursor-pointer outline-none"
      onchange="window.location.href = this.value"
      aria-label="Select language"
    >
      {locales.map((l) => (
        <option value={localizedPath(l, routePath || "/")} selected={l === locale} class="bg-[#0a0a0a] text-zinc-400">
          {localeLabels[l]}
        </option>
      ))}
    </select>
    <a href={localizedPath(locale, "/blog")} class="hover:text-zinc-400 transition-colors">{t.blog}</a>
    <a href="/terms/" class="hover:text-zinc-400 transition-colors">{t.terms}</a>
    <a href="/privacy/" class="hover:text-zinc-400 transition-colors">{t.privacy}</a>
  </nav>
</footer>
