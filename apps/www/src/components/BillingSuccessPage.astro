---
import Layout from "../layouts/Layout.astro";
import { ui, type Locale } from "../i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = ui[locale];
const apiUrl = import.meta.env.PUBLIC_API_URL || "";
const vaultsUrl = new URL("/vaults", apiUrl || Astro.url.origin).toString();
---

<Layout title={t.meta.billingSuccessTitle} description={t.meta.billingSuccessDescription} locale={locale}>
  <div class="max-w-2xl mx-auto px-6 w-full flex-1 flex flex-col">
    <main class="flex-1 flex flex-col items-center justify-center pb-32 text-center">
      <div id="spinner" class="animate-spin rounded-full h-8 w-8 border-2 border-zinc-600 border-t-zinc-200 mb-6" aria-hidden="true"></div>
      <h1 class="text-2xl text-zinc-200 tracking-tight mb-2">
        {t.billing.heading}
      </h1>
      <p id="message" class="text-zinc-500 text-sm max-w-md leading-relaxed">
        {t.billing.message}
      </p>

      <div id="actions" class="mt-8 hidden">
        <a
          href={vaultsUrl}
          class="px-4 py-2 text-sm bg-zinc-200 text-zinc-900 rounded-lg hover:bg-white transition-colors inline-block font-medium"
        >
          {t.billing.continue}
        </a>
      </div>
    </main>
  </div>
</Layout>

<script define:vars={{ apiUrl, fallbackMessage: t.billing.fallback, vaultsUrl }}>
  const message = document.getElementById("message");
  const actions = document.getElementById("actions");
  const spinner = document.getElementById("spinner");

  let startedAt = Date.now();
  let fallbackShown = false;
  let stopped = false;

  async function fetchStatus() {
    const response = await fetch(`${apiUrl}/v1/billing/status`, {
      credentials: "include",
      headers: { accept: "application/json" },
    });
    if (!response.ok) {
      throw new Error("status failed");
    }
    return await response.json();
  }

  async function poll() {
    if (stopped) {
      return;
    }

    try {
      const status = await fetchStatus();
      if (status.active) {
        stopped = true;
        window.location.href = vaultsUrl;
        return;
      }
    } catch {
      // Keep polling; the webhook may arrive shortly after the redirect.
    }

    const elapsed = Date.now() - startedAt;
    if (!fallbackShown && elapsed > 12000) {
      fallbackShown = true;
      if (actions) actions.classList.remove("hidden");
      if (spinner) spinner.classList.add("hidden");
      if (message) message.textContent = fallbackMessage;
    }

    window.setTimeout(poll, 1500);
  }

  poll();
</script>
