---
import type { CollectionEntry } from "astro:content";
import Footer from "./Footer.astro";
import Header from "./Header.astro";
import Layout from "../layouts/Layout.astro";
import { blogSlug, localizedPath, ui, type Locale } from "../i18n";

interface Props {
  locale: Locale;
  posts: CollectionEntry<"blog">[];
}

const { locale, posts } = Astro.props;
const t = ui[locale];
---

<Layout title={t.meta.blogTitle} description={t.meta.blogDescription} locale={locale}>
  <div class="max-w-2xl mx-auto px-6 w-full flex-1 flex flex-col">
    <Header locale={locale} />

    <main class="flex-1 py-16">
      <h1 class="text-3xl font-semibold text-zinc-200">{t.blog.heading}</h1>
      {
        posts.length > 0 ? (
          <ul class="mt-8 space-y-6">
            {posts.map((post) => {
              const slug = blogSlug(post.id, locale);

              return (
                <li>
                  <a class="text-xl font-medium text-zinc-200 hover:underline" href={localizedPath(locale, `/blog/${slug}`)}>
                    {post.data.title}
                  </a>
                  <p class="mt-2 text-zinc-500">{post.data.description}</p>
                  <time class="mt-2 block text-sm text-zinc-600" datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString(t.blog.dateLocale, {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </time>
                </li>
              );
            })}
          </ul>
        ) : (
          <p class="mt-4 text-zinc-500">{t.blog.empty}</p>
        )
      }
    </main>

    <Footer locale={locale} />
  </div>
</Layout>
