---
import type { AstroComponentFactory } from "astro/runtime/server/index.js";
import type { CollectionEntry } from "astro:content";
import Footer from "./Footer.astro";
import Header from "./Header.astro";
import Layout from "../layouts/Layout.astro";
import { type Locale } from "../i18n";

interface Props {
  Content: AstroComponentFactory;
  doc: CollectionEntry<"docs">;
  locale: Locale;
}

const { Content, doc, locale } = Astro.props;
---

<Layout title={`${doc.data.title} - Synch`} description={doc.data.description} locale={locale}>
  <div class="mx-auto flex w-full max-w-3xl flex-1 flex-col px-6">
    <Header locale={locale} />

    <main class="flex-1 py-20 sm:py-24">
      <article class="docs-content mx-auto w-full max-w-[68ch]">
        <header class="mb-12 border-b border-zinc-800/60 pb-10">
          <h1>{doc.data.title}</h1>
          <p class="mt-5 text-zinc-500">{doc.data.description}</p>
        </header>

        <Content />
      </article>
    </main>

    <Footer locale={locale} />
  </div>
</Layout>

<style is:global>
  @reference "../styles/global.css";
  .docs-content h1 {
    @apply text-3xl sm:text-4xl text-zinc-100 tracking-tight font-normal leading-tight;
  }
  .docs-content h2 {
    @apply text-xl sm:text-2xl text-zinc-200 font-normal mt-16 mb-6 tracking-tight leading-snug;
  }
  .docs-content h3 {
    @apply text-lg text-zinc-200 font-normal mt-12 mb-4 tracking-tight leading-snug;
  }
  .docs-content p {
    @apply text-[15px] sm:text-base text-zinc-300 mb-6 leading-8;
  }
  .docs-content blockquote {
    @apply my-8 rounded-md border border-dashed border-zinc-700 bg-zinc-900/35 px-5 py-4 text-zinc-400;
  }
  .docs-content blockquote p {
    @apply mb-0;
  }
  .docs-content pre {
    @apply overflow-x-auto rounded-md border border-zinc-800/70 bg-zinc-950 px-4 py-4 my-8 text-sm leading-6 text-zinc-300;
  }
  .docs-content code {
    @apply rounded bg-zinc-800/50 px-1.5 py-0.5 text-sm text-zinc-300 font-mono;
  }
  .docs-content pre code {
    @apply bg-transparent p-0 text-zinc-400;
  }
  .docs-content a {
    @apply text-zinc-300 underline decoration-zinc-700 hover:text-zinc-200 hover:decoration-zinc-500 transition-colors underline-offset-4;
  }
  .docs-content img {
    display: block;
    max-width: 100%;
    max-height: min(32rem, 70vh);
    width: auto;
    height: auto;
    margin: 2.5rem auto;
    border: 1px solid #27272a;
    border-radius: 6px;
    background: #fafafa;
    object-fit: contain;
  }
  .docs-content ul {
    @apply space-y-3.5 list-disc list-outside ml-5 mb-7 text-[15px] sm:text-base text-zinc-400 marker:text-zinc-700;
  }
  .docs-content ol {
    @apply space-y-3.5 list-decimal list-outside ml-5 mb-7 text-[15px] sm:text-base text-zinc-400 marker:text-zinc-700;
  }
  .docs-content li {
    @apply leading-8 pl-1;
  }
  .docs-content strong {
    @apply font-medium text-zinc-200;
  }
  .docs-content .synch-secret-generator {
    margin: 1.75rem 0 2.5rem;
    padding: 1rem;
    border: 1px solid #27272a;
    border-radius: 6px;
    background: rgba(9, 9, 11, 0.6);
  }
  .docs-content .synch-secret-title {
    margin: 0 0 0.375rem;
    color: #e4e4e7;
    font-size: 0.9375rem;
    font-weight: 500;
    line-height: 1.5rem;
    letter-spacing: 0;
  }
  .docs-content .synch-secret-generator p {
    margin: 0;
    color: #71717a;
    font-size: 0.8125rem;
    line-height: 1.5rem;
  }
  .docs-content .synch-secret-fields {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    margin-top: 1rem;
  }
  .docs-content .synch-secret-row label {
    display: block;
    margin-bottom: 0.5rem;
    color: #71717a;
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1rem;
  }
  .docs-content .synch-secret-control {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .docs-content .synch-secret-control input {
    min-width: 0;
    flex: 1 1 auto;
    padding: 0.4375rem 0.625rem;
    border: 1px solid #27272a;
    border-radius: 4px;
    background: #09090b;
    color: #d4d4d8;
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
      "Courier New", monospace;
    font-size: 0.75rem;
    line-height: 1.25rem;
    outline: none;
  }
  .docs-content .synch-secret-control button,
  .docs-content .synch-secret-generate-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2.125rem;
    padding: 0 0.875rem;
    border: 0;
    border-radius: 4px;
    background: #27272a;
    color: #e4e4e7;
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1rem;
    cursor: pointer;
    transition: background-color 150ms ease;
  }
  .docs-content .synch-secret-control button:hover,
  .docs-content .synch-secret-generate-button:hover {
    background: #3f3f46;
  }
  .docs-content .synch-secret-control button {
    width: 100%;
  }
  .docs-content .synch-secret-generate-button {
    width: 100%;
    margin-top: 1rem;
  }
  @media (min-width: 640px) {
    .docs-content .synch-secret-generator {
      padding: 1rem;
    }
    .docs-content .synch-secret-control {
      flex-direction: row;
    }
    .docs-content .synch-secret-control button {
      width: 6rem;
    }
    .docs-content .synch-secret-generate-button {
      width: auto;
    }
  }
</style>
