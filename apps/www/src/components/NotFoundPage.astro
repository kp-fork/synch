---
import Layout from "../layouts/Layout.astro";
import { localizedPath, ui, type Locale } from "../i18n";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = ui[locale];
---

<Layout title={t.meta.notFoundTitle} description={t.meta.notFoundDescription} locale={locale}>
	<div class="max-w-2xl mx-auto px-6 w-full flex-1 flex flex-col min-h-screen">
		<main class="flex-1 flex items-center">
			<section class="max-w-lg space-y-6">
				<p class="text-xs font-medium tracking-[0.24em] text-zinc-600 uppercase">
					{t.notFound.eyebrow}
				</p>
				<div class="space-y-4">
					<h1 class="text-2xl sm:text-3xl text-zinc-200 tracking-tight">
						{t.notFound.heading}
					</h1>
					<p class="max-w-md leading-relaxed text-zinc-500">
						{t.notFound.message}
					</p>
				</div>
				<div class="flex flex-wrap items-center gap-3 pt-4 text-xs">
					<a
						href={localizedPath(locale)}
						class="px-4 py-2 bg-zinc-800 text-zinc-200 hover:bg-zinc-700 rounded transition-colors"
					>
						{t.notFound.home}
					</a>
				</div>
			</section>
		</main>
	</div>
</Layout>
