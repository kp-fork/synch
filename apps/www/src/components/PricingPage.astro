---
import Footer from "./Footer.astro";
import Header from "./Header.astro";
import Layout from "../layouts/Layout.astro";
import { localizedPath, ui, type Locale } from "../i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = ui[locale];
const apiUrl = import.meta.env.PUBLIC_API_URL || "";
const authBaseUrl = apiUrl || Astro.url.origin;
const vaultsUrl = new URL("/vaults", authBaseUrl);
vaultsUrl.searchParams.set("lang", locale);
const signupUrl = new URL("/signup", authBaseUrl);
signupUrl.searchParams.set("return_to", vaultsUrl.toString());
signupUrl.searchParams.set("lang", locale);
const billingUrl = localizedPath(locale, "/billing");
const freeFeatures = [
  t.pricing.features.oneVault,
  t.pricing.features.freeStorage,
  t.pricing.features.freeFileSize,
  t.pricing.features.freeHistory,
];
const starterFeatures = [
  t.pricing.features.oneVault,
  t.pricing.features.starterStorage,
  t.pricing.features.starterFileSize,
  t.pricing.features.starterHistory,
];
---

<Layout title={t.meta.pricingTitle} description={t.meta.pricingDescription} locale={locale}>
  <div class="max-w-2xl mx-auto px-6 w-full flex-1 flex flex-col">
    <Header locale={locale} />

    <main class="flex-1 flex flex-col py-24">
      <div class="space-y-4 mb-20 text-center">
        <h1
          class="text-2xl sm:text-3xl text-zinc-200 tracking-tight"
        >
          {t.pricing.heading}
        </h1>
        <p class="text-zinc-500 max-w-md leading-relaxed mx-auto">
          {t.pricing.subheading}
        </p>
      </div>

      <div class="flex justify-center mb-6">
        <div
          class="grid grid-cols-2 gap-1 p-1 rounded bg-zinc-950/70 border border-zinc-800/50"
        >
          <button
            type="button"
            data-billing-interval="monthly"
            class="starter-billing-option min-w-20 px-3 py-2 rounded text-xs text-zinc-950 bg-zinc-200"
          >
            {t.pricing.monthly}
          </button>
          <button
            type="button"
            data-billing-interval="annual"
            class="starter-billing-option min-w-20 px-3 py-2 rounded text-xs text-zinc-400 hover:text-zinc-200"
          >
            {t.pricing.annual}
          </button>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 gap-6 max-w-2xl mx-auto w-full">
        <div
          class="p-6 rounded-lg border border-zinc-800/50 bg-zinc-900/20 flex flex-col"
        >
          <div class="mb-8">
            <h3 class="text-zinc-200 font-normal mb-2">{t.pricing.freePlan}</h3>
            <div class="flex items-baseline gap-1">
              <span class="text-2xl text-zinc-200">$0</span>
              <span class="text-xs text-zinc-500">{t.pricing.forever}</span>
            </div>
          </div>

          <ul class="space-y-4 mb-8 text-xs flex-1 text-zinc-400">
            {
              freeFeatures.map((feature) => (
                <li class="flex items-center gap-3">
                  <div class="w-1 h-1 rounded-full bg-zinc-600" />
                  {feature}
                </li>
              ))
            }
          </ul>

          <a
            href={signupUrl.toString()}
            class="w-full py-2 px-4 text-center text-xs bg-zinc-800 text-zinc-200 hover:bg-zinc-700 rounded transition-colors"
          >
            {t.home.getStarted}
          </a>
        </div>

        <div
          class="p-6 rounded-lg border border-zinc-800/50 bg-zinc-900/20 flex flex-col"
        >
          <div class="mb-8">
            <div class="mb-2 flex items-center gap-2">
              <h3 class="text-zinc-200 font-normal">
                {t.pricing.starterPlan}
              </h3>
              <span
                id="starter-discount-badge"
                class="hidden rounded border border-emerald-500/20 bg-emerald-500/10 px-2 py-0.5 text-[10px] font-medium text-emerald-300"
              >
                {t.pricing.annualDiscount}
              </span>
            </div>
            <div class="flex items-baseline gap-1">
              <span id="starter-price" class="text-2xl text-zinc-200">$1</span>
              <span id="starter-interval" class="text-xs text-zinc-500">
                {t.pricing.month}
              </span>
            </div>
          </div>

          <ul class="space-y-4 mb-8 text-xs flex-1 text-zinc-400">
            {
              starterFeatures.map((feature) => (
                <li class="flex items-center gap-3">
                  <div class="w-1 h-1 rounded-full bg-zinc-600" />
                  {feature}
                </li>
              ))
            }
          </ul>

          <button
            id="starter-checkout-button"
            type="button"
            class="w-full py-2 px-4 text-center text-xs bg-zinc-200 text-[#0a0a0a] hover:bg-white disabled:bg-zinc-800/50 disabled:text-zinc-500 disabled:cursor-not-allowed rounded transition-colors"
          >
            {t.home.getStarted}
          </button>
        </div>
      </div>
    </main>

    <Footer locale={locale} />
  </div>
</Layout>

<script define:vars={{ apiUrl, signupUrl: signupUrl.toString(), billingUrl, monthLabel: t.pricing.month, yearLabel: t.pricing.year }}>
  const starterCheckoutButton = document.getElementById("starter-checkout-button");
  const starterDiscountBadge = document.getElementById("starter-discount-badge");
  const starterPrice = document.getElementById("starter-price");
  const starterInterval = document.getElementById("starter-interval");
  const billingOptionButtons = Array.from(
    document.querySelectorAll(".starter-billing-option"),
  );
  let selectedBillingInterval = "monthly";

  const pricingByInterval = {
    monthly: {
      price: "$1",
      label: monthLabel,
      hasDiscount: false,
    },
    annual: {
      price: "$10",
      label: yearLabel,
      hasDiscount: true,
    },
  };

  function selectBillingInterval(billingInterval) {
    if (!(billingInterval in pricingByInterval)) {
      return;
    }

    selectedBillingInterval = billingInterval;
    const pricing = pricingByInterval[billingInterval];
    if (starterPrice) {
      starterPrice.textContent = pricing.price;
    }
    if (starterDiscountBadge) {
      starterDiscountBadge.classList.toggle("hidden", !pricing.hasDiscount);
    }
    if (starterInterval) {
      starterInterval.textContent = pricing.label;
    }

    for (const button of billingOptionButtons) {
      const isSelected = button.dataset.billingInterval === billingInterval;
      button.classList.toggle("bg-zinc-200", isSelected);
      button.classList.toggle("text-zinc-950", isSelected);
      button.classList.toggle("text-zinc-400", !isSelected);
      button.classList.toggle("hover:text-zinc-200", !isSelected);
    }
  }

  for (const button of billingOptionButtons) {
    button.addEventListener("click", () => {
      selectBillingInterval(button.dataset.billingInterval);
    });
  }

  if (starterCheckoutButton instanceof HTMLButtonElement) {
    starterCheckoutButton.addEventListener("click", async () => {
      starterCheckoutButton.disabled = true;

      try {
        const response = await fetch(`${apiUrl}/v1/billing/checkout`, {
          method: "POST",
          credentials: "include",
          headers: {
            accept: "application/json",
            "content-type": "application/json",
          },
          body: JSON.stringify({
            planId: "starter",
            billingInterval: selectedBillingInterval,
          }),
        });

        if (response.status === 401) {
          window.location.href = signupUrl;
          return;
        }
        if (response.status === 409) {
          window.location.href = billingUrl;
          return;
        }

        if (!response.ok) {
          throw new Error("checkout failed");
        }

        const checkout = await response.json();
        window.location.href = checkout.url;
      } catch {
        starterCheckoutButton.disabled = false;
      }
    });
  }
</script>
